# ─────────────────────────────────────────────────────────
# ContentStudio AI — Environment Configuration Template
# ─────────────────────────────────────────────────────────
# DO NOT commit actual secrets to this file or to .env
# Use environment variables or secret management systems
# ─────────────────────────────────────────────────────────

# Application
APP_NAME=ContentStudio AI Backend
ENV=development
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ── Database (Appwrite) — optional, leave blank to run without persistence ─
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=

# ── NVIDIA NIM ─────────────────────────────────────────────
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_FALLBACK_MODEL=meta/llama-3.1-8b-instruct

# ── Gamma AI (Carousel) ────────────────────────────────────
GAMMA_API_KEY=your_gamma_api_key_here

# ── Security ───────────────────────────────────────────────
# Used to derive the encryption key for stored social tokens — not for auth
# (this build has no authentication; every request runs as a local demo user)
SECRET_KEY=your_secret_key_here_minimum_32_characters

# Dedicated key for encrypting stored social tokens. If unset, falls back to
# a key derived from SECRET_KEY. REQUIRED when ENV=production (no fallback).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=

# This build's auth layer is stubbed out (every request runs as a shared demo
# user). The app refuses to start with ENV=production unless you explicitly
# set this to true — only do so after wiring up real authentication, or if
# you fully understand and accept the risk of an open, unauthenticated API.
ALLOW_DEMO_AUTH_IN_PRODUCTION=false

# Number of trusted reverse-proxy hops that append to X-Forwarded-For (e.g. 1
# for a single ingress/load balancer in front of this app). Leave at 0 (the
# default) unless you have a known, configured proxy chain — the header is a
# client-controlled value otherwise and must not be trusted for rate limiting.
TRUSTED_PROXY_COUNT=0

# ── URLs ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000/api/v1

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ── Redis (Distributed Rate Limiting & Caching) ────────────
REDIS_URL=redis://localhost:6379

# ── Email Service ──────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
MAIL_FROM=noreply@example.com

# ── Twitter / X ────────────────────────────────────────────
# https://developer.twitter.com/en/portal/dashboard
# Scopes needed: tweet.read tweet.write users.read offline.access
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_CALLBACK_URL=https://your-api-domain/api/v1/social/oauth/twitter/callback

# ── LinkedIn OAuth 2.0 ─────────────────────────────────────
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=https://your-api-domain/api/v1/social/oauth/linkedin/callback

# ── Meta (Instagram + Facebook) ────────────────────────────
# https://developers.facebook.com/apps/
META_APP_ID=
META_APP_SECRET=
META_CALLBACK_URL=https://your-api-domain/api/v1/social/oauth/instagram/callback
FACEBOOK_CALLBACK_URL=https://your-api-domain/api/v1/social/oauth/facebook/callback

# ── Viral Intel — RAG Trend Scouting ────────────────────────
#
# ① Reddit API (FREE — 2 min setup)
#    → https://www.reddit.com/prefs/apps
#    → Click "create another app" → choose "script"
#    → Name: ContentStudio, redirect: http://localhost:8080
#    → Copy the client_id (under app name) and secret
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ContentStudio/1.0
#
# ② YouTube Data API v3 (FREE — 10,000 units/day)
#    → https://console.cloud.google.com/
#    → Create project → Enable "YouTube Data API v3"
#    → Credentials → Create API Key → restrict to YouTube Data API
YOUTUBE_DATA_API_KEY=
#
# ③ Instagram Scraper (FREE — use any IG account, public posts only)
#    → Create a spare Instagram account (or use existing)
#    → We use Playwright to browse public hashtag pages as that user
#    → Only reads public trending posts — no private data
INSTAGRAM_SCRAPER_USERNAME=
INSTAGRAM_SCRAPER_PASSWORD=
#
# ④ X / Twitter Scraper (FREE — twikit, uses a spare Twitter account)
#    → Logs in once, saves session cookies, re-uses them on every scan
#    → Only reads public tweets — no private data accessed
TWITTER_SCRAPER_USERNAME=
TWITTER_SCRAPER_PASSWORD=
TWITTER_SCRAPER_EMAIL=
#
# ⑤ Browserless (FREE — self-hosted Docker, stealth headless Chrome)
#    → Gives TikTok trend data + Instagram/Twitter fallback via Google Search
#    → No API key needed. Run once, works forever:
#       docker run -p 3000:3000 --restart always -d browserless/chrome:latest
BROWSERLESS_URL=http://localhost:3000
#
# ✅ Google Trends + RSS Feeds + Hacker News + Mastodon + Wikipedia work with ZERO keys — always active
